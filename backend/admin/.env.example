# ──────────────────────────────────────────────────────────────
# HillNest Admin Service — Environment Variables
# Copy to .env and fill in all values
# ──────────────────────────────────────────────────────────────

# ── Server ──
NODE_ENV=development
PORT=5001
HOST=0.0.0.0
API_VERSION=v1

# ── PostgreSQL ──
DATABASE_URL=postgresql://hillnest_admin:CHANGE_ME@localhost:5432/hillnest_admin?schema=public

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── JWT (use RS256 — generate with: openssl genrsa -out private.pem 2048) ──
# Paste the base64-encoded content of the PEM files here
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_SECRET_MIN_64_CHARS_FOR_HMAC_OR_USE_RS256
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=hillnest-admin

# ── MFA ──
MFA_APP_NAME=HillNest Admin
# AES-256 key for encrypting TOTP secrets in DB (32 bytes hex)
MFA_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY_HERE_EXACTLY_64_CHARS

# ── CORS ──
ADMIN_FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=300000

# ── Account Lockout ──
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── AWS S3 Compatible Storage ──
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=hillnest-uploads
S3_PUBLIC_URL=https://hillnest-uploads.s3.ap-south-1.amazonaws.com

# ── Email (SMTP / Nodemailer) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@hillnest.in
SMTP_PASS=CHANGE_ME
EMAIL_FROM_NAME=HillNest Admin
EMAIL_FROM_ADDRESS=noreply@hillnest.in

# ── Logging ──
LOG_LEVEL=info
LOG_FORMAT=json

# ── Monitoring ──
PROMETHEUS_METRICS_PATH=/metrics
OTEL_SERVICE_NAME=hillnest-admin-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── MongoDB (existing customer data) ──
MONGO_URI=mongodb+srv://sahil:sahil123@cluster0.8va2awa.mongodb.net/?appName=Cluster0
MONGO_DB=sahil
